# ── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://smartload:smartload123@localhost:5433/smartload_db
DIRECT_DATABASE_URL=postgresql://smartload:smartload123@localhost:5433/smartload_db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_MIN_64_CHAR_RANDOM_STRING_FOR_ACCESS_TOKENS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_MIN_64_CHAR_RANDOM_STRING
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── AWS S3 / File Storage ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_BUCKET=smartload-files-dev
AWS_REGION=ap-south-1
# For local dev use MinIO:
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true

# ── SMS — MSG91 (India) ──────────────────────────────────────────────────────
MSG91_API_KEY=your_msg91_api_key
MSG91_SENDER_ID=SMLDSM
MSG91_TEMPLATE_ID_POD_DISPATCH=your_template_id
MSG91_TEMPLATE_ID_OTP=your_otp_template_id
MSG91_TEMPLATE_ID_LOW_STOCK=your_low_stock_template_id

# ── WhatsApp — WATI ──────────────────────────────────────────────────────────
WATI_API_ENDPOINT=https://live-mt-server.wati.io/YOUR_ACCOUNT_ID
WATI_API_TOKEN=your_wati_bearer_token
WATI_TEMPLATE_POD_DISPATCH=pod_dispatch_notification

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=dispatch@yourcompany.in
SMTP_PASS=your_app_password
SMTP_FROM_NAME=SmartLoad Dispatch
SMTP_FROM_EMAIL=dispatch@yourcompany.in

# ── Tally Bridge ─────────────────────────────────────────────────────────────
TALLY_BRIDGE_URL=http://localhost:7474
TALLY_BRIDGE_SECRET=REPLACE_WITH_SHARED_SECRET_BETWEEN_API_AND_BRIDGE

# ── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_WHATSAPP=false
ENABLE_SMS=false
ENABLE_TALLY_SYNC=false

# ── Frontend (Vite) ─────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
VITE_APP_NAME=SmartLoad
