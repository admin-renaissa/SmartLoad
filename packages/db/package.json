{
  "name": "@smartload/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "generate": "prisma generate",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "typecheck": "dotenv -e ../../.env -- prisma validate",
    "lint": "echo \"skip\"",
    "build": "prisma generate",
    "test": "echo \"skip\""
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.15.1",
    "typescript": "^5.4.0"
  },
  "prisma": {
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts"
  }
}
