# ─────────────────────────────────────────────────────────────
# SmartLoad Tally Bridge — Environment Configuration
# Copy this file to .env and fill in values for your installation
# ─────────────────────────────────────────────────────────────

# ── Bridge server ─────────────────────────────────────────────
# Port this bridge listens on (keep default unless conflicting)
BRIDGE_PORT=7474

# Bind address — keep 127.0.0.1 unless exposed via VPN/tunnel
BRIDGE_HOST=127.0.0.1

# Shared secret for Bearer auth (must match TALLY_BRIDGE_SECRET in cloud API .env)
TALLY_BRIDGE_SECRET=REPLACE_WITH_SHARED_SECRET

# ── TallyPrime connection ─────────────────────────────────────
# URL of the TallyPrime HTTP server (running on same machine)
TALLY_URL=http://localhost:9000

# HTTP request timeout in milliseconds
TALLY_HTTP_TIMEOUT_MS=15000

# TallyPrime company name (must exactly match the company name in Tally)
TALLY_COMPANY_NAME=Your Company Pvt Ltd

# Godown / warehouse location name in TallyPrime
TALLY_GODOWN=Main Warehouse

# Optional: default vendor ledger name for GRN push
TALLY_DEFAULT_VENDOR_LEDGER=

# ── SmartLoad Cloud API (for push notifications back to cloud) ─
SMARTLOAD_API_URL=https://api.yoursmartload.in
SMARTLOAD_API_KEY=your_internal_api_key

# ── Tally pull configuration ──────────────────────────────────
# Ledger report name (default: List of Ledgers)
TALLY_LEDGER_REPORT=List of Ledgers

# Purchase order report (default: Voucher Register)
TALLY_PO_REPORT=Voucher Register

# Date range for PO pull (YYYYMMDD). Leave empty for last 2 years.
# TALLY_PO_FROM=20240101
# TALLY_PO_TO=20241231

# Optional voucher type filter for Tally (e.g. Purchase, Sales)
TALLY_PO_SVVOUCHERTYPENAME=
TALLY_PO_VOUCHER_TYPE_FILTER=

# ── Polling ───────────────────────────────────────────────────
# How often the bridge pings TallyPrime to check reachability (ms)
# Set to 0 to disable background polling
TALLY_POLL_INTERVAL_MS=60000

# ── Logging ──────────────────────────────────────────────────
# Log level: error | warn | info | debug
LOG_LEVEL=info

# Directory for HTTP request/response logs (daily rotation)
TALLY_BRIDGE_LOG_DIR=./logs

# ── Node environment ──────────────────────────────────────────
NODE_ENV=production
