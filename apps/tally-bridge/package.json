{
  "name": "@smartload/tally-bridge",
  "version": "1.0.0",
  "description": "SmartLoad Tally Bridge — Windows Service connecting TallyPrime to SmartLoad cloud",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev":               "tsx watch src/index.ts",
    "build":             "tsc",
    "start":             "node dist/index.js",
    "install-service":   "node dist/service/install.js",
    "uninstall-service": "node dist/service/uninstall.js",
    "typecheck":         "tsc --noEmit",
    "test":              "vitest run"
  },
  "dependencies": {
    "fastify":                   "^4.27.0",
    "@fastify/cors":             "^9.0.1",
    "axios":                     "^1.7.2",
    "fast-xml-parser":           "^4.3.6",
    "winston":                   "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod":                       "^3.23.0",
    "dotenv":                    "^16.4.0",
    "node-windows":              "^1.0.0-beta.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.1",
    "tsx":         "^4.15.1",
    "typescript":  "^5.4.5",
    "vitest":      "^1.6.0"
  }
}
